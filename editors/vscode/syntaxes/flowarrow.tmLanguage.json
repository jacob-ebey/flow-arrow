{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FlowArrow",
  "scopeName": "source.flowarrow",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#forbidden-keywords"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#combinators"
    },
    {
      "include": "#struct-literals"
    },
    {
      "include": "#node-references"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.flowarrow",
          "match": "#.*$"
        },
        {
          "name": "comment.block.flowarrow",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.flowarrow",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.flowarrow",
          "match": "\\\\[\"\\\\ntr]"
        },
        {
          "name": "invalid.illegal.escape.flowarrow",
          "match": "\\\\."
        }
      ]
    },
    "forbidden-keywords": {
      "name": "invalid.illegal.keyword.flowarrow",
      "match": "\\b(?:for|while|break|continue|return|throw|try|catch|await|spawn|join|lock|mutex|atomic|var|set|if|else|take_while|find_first)\\b|(?:\\+\\+|--|\\+=|-=|\\*=|/=)"
    },
    "variables": {
      "name": "variable.other.flowarrow",
      "match": "(\\$)([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.definition.variable.flowarrow"
        },
        "2": {
          "name": "variable.other.flowarrow"
        }
      }
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.foreign.flowarrow",
          "match": "\\b(foreign)\\s+(js)\\s+(module|global)\\s+(\"(?:\\\\[\"\\\\ntr]|[^\"\\\\])*\")",
          "captures": {
            "1": {
              "name": "keyword.declaration.foreign.flowarrow"
            },
            "2": {
              "name": "support.type.foreign-target.flowarrow"
            },
            "3": {
              "name": "keyword.other.foreign-source.flowarrow"
            },
            "4": {
              "name": "string.quoted.double.flowarrow"
            }
          }
        },
        {
          "name": "meta.declaration.foreign-c.flowarrow",
          "match": "\\b(foreign)\\s+(c)\\s+(header)\\s+(\"(?:\\\\[\"\\\\ntr]|[^\"\\\\])*\")(?:\\s+(source)\\s+(\"(?:\\\\[\"\\\\ntr]|[^\"\\\\])*\"))?",
          "captures": {
            "1": {
              "name": "keyword.declaration.foreign.flowarrow"
            },
            "2": {
              "name": "support.type.foreign-target.flowarrow"
            },
            "3": {
              "name": "keyword.other.foreign-source.flowarrow"
            },
            "4": {
              "name": "string.quoted.double.flowarrow"
            },
            "5": {
              "name": "keyword.other.foreign-source.flowarrow"
            },
            "6": {
              "name": "string.quoted.double.flowarrow"
            }
          }
        },
        {
          "name": "meta.declaration.foreign-node.flowarrow",
          "match": "\\b(pure|io)\\s+(node)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.effect.flowarrow"
            },
            "2": {
              "name": "keyword.declaration.flowarrow"
            },
            "3": {
              "name": "entity.name.function.flowarrow"
            }
          }
        },
        {
          "name": "meta.declaration.node.flowarrow",
          "match": "\\b(?:(extern)\\s+)?(node|program)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.flowarrow"
            },
            "2": {
              "name": "keyword.declaration.flowarrow"
            },
            "3": {
              "name": "entity.name.function.flowarrow"
            }
          }
        },
        {
          "name": "meta.declaration.type.flowarrow",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.flowarrow"
            },
            "2": {
              "name": "entity.name.type.alias.flowarrow"
            },
            "3": {
              "name": "punctuation.separator.type-alias.flowarrow"
            }
          }
        },
        {
          "name": "meta.declaration.struct.flowarrow",
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.struct.flowarrow"
            },
            "2": {
              "name": "entity.name.type.struct.flowarrow"
            }
          }
        },
        {
          "name": "meta.cell.flowarrow",
          "match": "\\b(cell)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "keyword.declaration.cell.flowarrow"
            }
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.local.flowarrow",
          "match": "\\b(import)\\s+(\"(?:\\\\[\"\\\\ntr]|[^\"\\\\])*\")",
          "captures": {
            "1": {
              "name": "keyword.control.import.flowarrow"
            },
            "2": {
              "name": "string.quoted.double.flowarrow"
            }
          }
        },
        {
          "name": "meta.import.flowarrow",
          "match": "\\b(import)\\s+((?:[A-Za-z_][A-Za-z0-9_]*)(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.flowarrow"
            },
            "2": {
              "name": "support.module.flowarrow"
            }
          }
        },
        {
          "name": "keyword.control.import.alias.flowarrow",
          "match": "\\b(as)\\b"
        },
        {
          "name": "support.module.std.flowarrow",
          "match": "\\bstd(?:\\.[A-Za-z_][A-Za-z0-9_]*)*\\b"
        }
      ]
    },
    "combinators": {
      "patterns": [
        {
          "name": "meta.combinator.fault-map.flowarrow",
          "match": "\\b(fault)\\s+(map)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "support.function.builtin.flowarrow"
            },
            "3": {
              "name": "entity.name.function.flowarrow"
            }
          }
        },
        {
          "name": "meta.combinator.map.flowarrow",
          "match": "\\b(map|filter)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "entity.name.function.flowarrow"
            }
          }
        },
        {
          "name": "meta.combinator.field.flowarrow",
          "match": "\\b(field)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "variable.other.member.flowarrow"
            }
          }
        },
        {
          "name": "meta.combinator.reduce.flowarrow",
          "match": "\\b(reduce|scan)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()\\s*(identity)\\s*(:)",
          "captures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "entity.name.function.flowarrow"
            },
            "3": {
              "name": "punctuation.definition.group.flowarrow"
            },
            "4": {
              "name": "keyword.other.identity.flowarrow"
            },
            "5": {
              "name": "punctuation.separator.type.flowarrow"
            }
          }
        },
        {
          "name": "meta.combinator.repeat.runtime.flowarrow",
          "match": "\\b(repeat)\\s*(<)\\s*(\\$)([A-Za-z_][A-Za-z0-9_]*)\\s*(>)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "punctuation.definition.typeparameters.begin.flowarrow"
            },
            "3": {
              "name": "punctuation.definition.variable.flowarrow"
            },
            "4": {
              "name": "variable.other.flowarrow"
            },
            "5": {
              "name": "punctuation.definition.typeparameters.end.flowarrow"
            },
            "6": {
              "name": "entity.name.function.flowarrow"
            }
          }
        },
        {
          "name": "meta.combinator.repeat.literal.flowarrow",
          "match": "\\b(repeat)\\s*(<)\\s*(-?\\d+)\\s*(>)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "punctuation.definition.typeparameters.begin.flowarrow"
            },
            "3": {
              "name": "constant.numeric.integer.flowarrow"
            },
            "4": {
              "name": "punctuation.definition.typeparameters.end.flowarrow"
            },
            "5": {
              "name": "entity.name.function.flowarrow"
            }
          }
        },
        {
          "name": "meta.combinator.stencil.flowarrow",
          "match": "\\b(stencil2d)\\s+(radius)\\s*(<)\\s*(-?\\d+)\\s*(>)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "keyword.other.radius.flowarrow"
            },
            "3": {
              "name": "punctuation.definition.typeparameters.begin.flowarrow"
            },
            "4": {
              "name": "constant.numeric.integer.flowarrow"
            },
            "5": {
              "name": "punctuation.definition.typeparameters.end.flowarrow"
            },
            "6": {
              "name": "entity.name.function.flowarrow"
            }
          }
        },
        {
          "name": "meta.combinator.grid.flowarrow",
          "begin": "\\b(grid)\\s*(<)",
          "beginCaptures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "punctuation.definition.typeparameters.begin.flowarrow"
            }
          },
          "end": ">",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.typeparameters.end.flowarrow"
            }
          },
          "patterns": [
            {
              "include": "#variables"
            },
            {
              "include": "#numbers"
            },
            {
              "name": "variable.parameter.grid.flowarrow",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.comma.flowarrow",
              "match": ","
            }
          ]
        },
        {
          "name": "meta.combinator.match.flowarrow",
          "begin": "\\b(match)\\s*(\\{)",
          "beginCaptures": {
            "1": {
              "name": "support.function.builtin.flowarrow"
            },
            "2": {
              "name": "punctuation.definition.block.flowarrow"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.block.flowarrow"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#match-arms"
            },
            {
              "include": "#node-references"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#punctuation"
            }
          ]
        },
        {
          "name": "support.function.builtin.flowarrow",
          "match": "\\b(?:select|match|range|range_between|range_step|length|field)\\b"
        },
        {
          "name": "keyword.other.identity.flowarrow",
          "match": "\\bidentity\\b"
        },
        {
          "name": "keyword.other.radius.flowarrow",
          "match": "\\bradius\\b"
        }
      ]
    },
    "match-arms": {
      "patterns": [
        {
          "name": "meta.match.guard.flowarrow",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*(\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.flowarrow"
            },
            "2": {
              "name": "punctuation.definition.group.flowarrow"
            }
          }
        },
        {
          "name": "keyword.operator.fallback.flowarrow",
          "match": "\\b_\\b(?=\\s*->)"
        }
      ]
    },
    "struct-literals": {
      "patterns": [
        {
          "name": "meta.struct-literal.flowarrow",
          "begin": "(^\\s*|(?<=->)\\s*|(?<=[(\\[,])\\s*)([A-Z][A-Za-z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "2": {
              "name": "entity.name.type.struct.flowarrow"
            },
            "3": {
              "name": "punctuation.definition.block.flowarrow"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.block.flowarrow"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#combinators"
            },
            {
              "include": "#struct-literals"
            },
            {
              "name": "variable.other.member.flowarrow",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*:)"
            },
            {
              "include": "#types"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "node-references": {
      "patterns": [
        {
          "name": "meta.stage.node.flowarrow",
          "match": "(-)(>)\\s*(?!(?:map|reduce|scan|repeat|fault|filter|field|select|match|stencil2d|grid|range|range_between|range_step|length)\\b)([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": {
              "name": "keyword.control.flowarrow"
            },
            "2": {
              "name": "keyword.control.flowarrow"
            },
            "3": {
              "name": "entity.name.function.flowarrow"
            }
          }
        }
      ]
    },
    "keywords": {
      "name": "keyword.other.reserved.flowarrow",
      "match": "\\b(?:import|as|type|struct|foreign|pure|io|module|global|header|source|c|js|extern|node|program|cell|fault|ok|match|field)\\b"
    },
    "booleans": {
      "name": "constant.language.boolean.flowarrow",
      "match": "\\b(?:true|false)\\b"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.real.flowarrow",
          "match": "(?<![A-Za-z0-9_])-?\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.flowarrow",
          "match": "(?<![A-Za-z0-9_])-?\\d+\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.flowarrow",
          "match": "\\b(?:Args|Bool|Bytes|Connection|Fault|Faultable|Image|Int|Kernel|Matrix|Real|Row|Seq|Stream|Value|Vec|double|i64)\\b"
        },
        {
          "name": "meta.type.annotation.flowarrow",
          "match": "(:)\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*(?:\\[[^\\]]*\\])?(?:\\|[A-Za-z_][A-Za-z0-9_]*(?:\\[[^\\]]*\\])?)*)",
          "captures": {
            "1": {
              "name": "punctuation.separator.type.flowarrow"
            },
            "2": {
              "name": "entity.name.type.flowarrow"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.control.flowarrow",
          "match": "(-)(>)",
          "captures": {
            "1": {
              "name": "keyword.control.flowarrow"
            },
            "2": {
              "name": "keyword.control.flowarrow"
            }
          }
        },
        {
          "name": "keyword.operator.accessor.flowarrow",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.flowarrow",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.group.flowarrow",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.sequence.flowarrow",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.comma.flowarrow",
          "match": ","
        },
        {
          "name": "punctuation.separator.type.flowarrow",
          "match": ":"
        },
        {
          "name": "punctuation.separator.type-alias.flowarrow",
          "match": "="
        },
        {
          "name": "punctuation.definition.typeparameters.flowarrow",
          "match": "[<>]"
        },
        {
          "name": "punctuation.definition.variable.flowarrow",
          "match": "\\$"
        }
      ]
    }
  }
}
