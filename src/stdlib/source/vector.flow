import std.math {
    add as _scalar_add,
    sub as _scalar_sub,
    mul as _scalar_mul,
    div as _scalar_div,
    neg as _scalar_neg,
    abs as _scalar_abs,
    sqrt as _scalar_sqrt,
    eq as _scalar_eq,
}
import std.predicates { all }
import std.seq { length, zip, broadcast_left, broadcast_right }
import std.tuple { first, second }

node sum(values: Seq[Real]) -> total: Real {
    $values -> reduce _scalar_add(identity: 0.0) -> $total
}

node mean(values: Seq[Real]) -> average: Real {
    $values -> sum -> $total
    $values -> length -> $count
    ($total, $count) -> _scalar_div -> $average
}

node _add_pair(pair: (Real,Real)) -> out: Real {
    $pair -> _scalar_add -> $out
}

node _sub_pair(pair: (Real,Real)) -> out: Real {
    $pair -> _scalar_sub -> $out
}

node _mul_pair(pair: (Real,Real)) -> out: Real {
    $pair -> _scalar_mul -> $out
}

node _div_pair(pair: (Real,Real)) -> out: Real {
    $pair -> _scalar_div -> $out
}

node _eq_pair(pair: (Real,Real)) -> out: Bool {
    $pair -> _scalar_eq -> $out
}

node _neg_value(value: Real) -> out: Real {
    $value -> _scalar_neg -> $out
}

node _abs_value(value: Real) -> out: Real {
    $value -> _scalar_abs -> $out
}

node neg(values: Seq[Real]) -> out: Seq[Real] {
    $values -> map _neg_value -> $out
}

node abs(values: Seq[Real]) -> out: Seq[Real] {
    $values -> map _abs_value -> $out
}

node add(inputs: (Seq[Real],Seq[Real])) -> out: Seq[Real] {
    $inputs -> zip -> map _add_pair -> $out
}

node sub(inputs: (Seq[Real],Seq[Real])) -> out: Seq[Real] {
    $inputs -> zip -> map _sub_pair -> $out
}

node mul(inputs: (Seq[Real],Seq[Real])) -> out: Seq[Real] {
    $inputs -> zip -> map _mul_pair -> $out
}

node div(inputs: (Seq[Real],Seq[Real])) -> out: Seq[Real] {
    $inputs -> zip -> map _div_pair -> $out
}

node add_scalar(inputs: (Seq[Real],Real)) -> out: Seq[Real] {
    $inputs -> broadcast_right -> map _add_pair -> $out
}

node sub_scalar(inputs: (Seq[Real],Real)) -> out: Seq[Real] {
    $inputs -> broadcast_right -> map _sub_pair -> $out
}

node scalar_sub(inputs: (Real,Seq[Real])) -> out: Seq[Real] {
    $inputs -> broadcast_left -> map _sub_pair -> $out
}

node mul_scalar(inputs: (Seq[Real],Real)) -> out: Seq[Real] {
    $inputs -> broadcast_right -> map _mul_pair -> $out
}

node scalar_mul(inputs: (Real,Seq[Real])) -> out: Seq[Real] {
    $inputs -> broadcast_left -> map _mul_pair -> $out
}

node div_scalar(inputs: (Seq[Real],Real)) -> out: Seq[Real] {
    $inputs -> broadcast_right -> map _div_pair -> $out
}

node scalar_div(inputs: (Real,Seq[Real])) -> out: Seq[Real] {
    $inputs -> broadcast_left -> map _div_pair -> $out
}

node equals(inputs: (Seq[Real],Seq[Real])) -> out: Bool {
    $inputs -> zip -> map _eq_pair -> all -> $out
}

node _dot_pair(pair: (Real,Real)) -> product: Real {
    $pair -> _scalar_mul -> $product
}

node dot(inputs: (Seq[Real],Seq[Real])) -> total: Real {
    $inputs -> zip -> map _dot_pair -> reduce _scalar_add(identity: 0.0) -> $total
}

node _square(value: Real) -> out: Real {
    ($value, $value) -> _scalar_mul -> $out
}

node squared_norm(values: Seq[Real]) -> total: Real {
    $values -> map _square -> sum -> $total
}

node l1_norm(values: Seq[Real]) -> total: Real {
    $values -> abs -> sum -> $total
}

node norm(values: Seq[Real]) -> total: Real {
    $values -> squared_norm -> _scalar_sqrt -> $total
}

node normalize(values: Seq[Real]) -> out: Seq[Real] {
    $values -> norm -> $magnitude
    ($values, $magnitude) -> div_scalar -> $out
}

node cosine_similarity(inputs: (Seq[Real],Seq[Real])) -> out: Real {
    $inputs -> dot -> $numerator
    $inputs -> first -> norm -> $left_norm
    $inputs -> second -> norm -> $right_norm
    ($left_norm, $right_norm) -> _scalar_mul -> $denominator
    ($numerator, $denominator) -> _scalar_div -> $out
}

node squared_distance(inputs: (Seq[Real],Seq[Real])) -> total: Real {
    $inputs -> sub -> squared_norm -> $total
}

node distance(inputs: (Seq[Real],Seq[Real])) -> total: Real {
    $inputs -> squared_distance -> _scalar_sqrt -> $total
}
