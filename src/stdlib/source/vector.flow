import std.math {
    add_f64 as math_add,
    sub_f64 as math_sub,
    mul_f64 as math_mul,
    div_f64 as math_div,
    neg_f64 as math_neg,
    abs_f64 as math_abs,
    sqrt_f64 as math_sqrt,
    exp_f64 as math_exp,
    eq_f64 as math_eq,
    min_f64 as math_min,
    max_f64 as math_max,
    add_f32 as math_add_f32,
    sub_f32 as math_sub_f32,
    mul_f32 as math_mul_f32,
    div_f32 as math_div_f32,
    neg_f32 as math_neg_f32,
    abs_f32 as math_abs_f32,
    sqrt_f32 as math_sqrt_f32,
    exp_f32 as math_exp_f32,
    eq_f32 as math_eq_f32,
    min_f32 as math_min_f32,
    max_f32 as math_max_f32,
}
import std.fault { expect }
import std.predicates { all }
import std.real { from_int, from_int_f32 }
import std.seq {
    length,
    head,
    tail,
    zip,
    broadcast_left,
    broadcast_right,
}
import std.tuple { first, second }

extern node sum_f64(values: Seq[f64]) -> total: f64 {
    $values -> reduce math_add(identity: 0.0) -> $total
}

extern node mean_f64(values: Seq[f64]) -> average: f64 {
    $values          -> sum_f64  -> $total
    $values          -> length   -> from_int -> $count
    ($total, $count) -> math_div -> expect   -> $average
}

extern node min_f64(values: Seq[f64]) -> out: f64 {
    $values -> head -> expect                              -> $initial
    $values -> tail -> reduce math_min(identity: $initial) -> $out
}

extern node max_f64(values: Seq[f64]) -> out: f64 {
    $values -> head -> expect                              -> $initial
    $values -> tail -> reduce math_max(identity: $initial) -> $out
}

node add_pair(pair: (f64, f64)) -> out: f64 {
    $pair -> math_add -> $out
}

node sub_pair(pair: (f64, f64)) -> out: f64 {
    $pair -> math_sub -> $out
}

node mul_pair(pair: (f64, f64)) -> out: f64 {
    $pair -> math_mul -> $out
}

node div_pair(pair: (f64, f64)) -> out: f64 {
    $pair -> math_div -> expect -> $out
}

node eq_pair(pair: (f64, f64)) -> out: Bool {
    $pair -> math_eq -> $out
}

node neg_value(value: f64) -> out: f64 {
    $value -> math_neg -> $out
}

node abs_value(value: f64) -> out: f64 {
    $value -> math_abs -> $out
}

extern node neg_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values -> map neg_value -> $out
}

extern node abs_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values -> map abs_value -> $out
}

node exp_value(value: f64) -> out: f64 {
    $value -> math_exp -> $out
}

extern node exp_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values -> map exp_value -> $out
}

extern node add_f64(inputs: (Seq[f64], Seq[f64])) -> out: Seq[f64] {
    $inputs -> zip -> map add_pair -> $out
}

extern node sub_f64(inputs: (Seq[f64], Seq[f64])) -> out: Seq[f64] {
    $inputs -> zip -> map sub_pair -> $out
}

extern node mul_f64(inputs: (Seq[f64], Seq[f64])) -> out: Seq[f64] {
    $inputs -> zip -> map mul_pair -> $out
}

extern node div_f64(inputs: (Seq[f64], Seq[f64])) -> out: Seq[f64] {
    $inputs -> zip -> map div_pair -> $out
}

extern node add_scalar_f64(inputs: (Seq[f64], f64)) -> out: Seq[f64] {
    $inputs -> broadcast_right -> map add_pair -> $out
}

extern node sub_scalar_f64(inputs: (Seq[f64], f64)) -> out: Seq[f64] {
    $inputs -> broadcast_right -> map sub_pair -> $out
}

extern node scalar_sub_f64(inputs: (f64, Seq[f64])) -> out: Seq[f64] {
    $inputs -> broadcast_left -> map sub_pair -> $out
}

extern node mul_scalar_f64(inputs: (Seq[f64], f64)) -> out: Seq[f64] {
    $inputs -> broadcast_right -> map mul_pair -> $out
}

extern node scalar_mul_f64(inputs: (f64, Seq[f64])) -> out: Seq[f64] {
    $inputs -> broadcast_left -> map mul_pair -> $out
}

extern node div_scalar_f64(inputs: (Seq[f64], f64)) -> out: Seq[f64] {
    $inputs -> broadcast_right -> map div_pair -> $out
}

extern node scalar_div_f64(inputs: (f64, Seq[f64])) -> out: Seq[f64] {
    $inputs -> broadcast_left -> map div_pair -> $out
}

extern node equals_f64(inputs: (Seq[f64], Seq[f64])) -> out: Bool {
    $inputs -> zip -> map eq_pair -> all -> $out
}

node dot_pair(pair: (f64, f64)) -> product: f64 {
    $pair -> math_mul -> $product
}

extern node dot_f64(inputs: (Seq[f64], Seq[f64])) -> total: f64 {
    $inputs -> zip -> map dot_pair -> reduce math_add(identity: 0.0) -> $total
}

node square(value: f64) -> out: f64 {
    ($value, $value) -> math_mul -> $out
}

extern node squared_norm_f64(values: Seq[f64]) -> total: f64 {
    $values -> map square -> sum_f64 -> $total
}

extern node l1_norm_f64(values: Seq[f64]) -> total: f64 {
    $values -> abs_f64 -> sum_f64 -> $total
}

extern node norm_f64(values: Seq[f64]) -> total: f64 {
    $values -> squared_norm_f64 -> math_sqrt -> expect -> $total
}

extern node normalize_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values               -> norm_f64       -> $magnitude
    ($values, $magnitude) -> div_scalar_f64 -> $out
}

node relu_value(value: f64) -> out: f64 {
    ($value, 0.0) -> math_max -> $out
}

extern node relu_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values -> map relu_value -> $out
}

extern node sigmoid_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values             -> neg_f64        -> exp_f64 -> $neg_exp
    ($neg_exp, 1.0)     -> add_scalar_f64 -> $denominator
    (1.0, $denominator) -> scalar_div_f64 -> $out
}

extern node silu_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values               -> sigmoid_f64 -> $activated
    ($values, $activated) -> mul_f64     -> $out
}

extern node softmax_f64(values: Seq[f64]) -> out: Seq[f64] {
    $values                     -> max_f64        -> $offset
    ($values, $offset)          -> sub_scalar_f64 -> exp_f64 -> $exp_values
    $exp_values                 -> sum_f64        -> $denominator
    ($exp_values, $denominator) -> div_scalar_f64 -> $out
}

extern node cosine_similarity_f64(inputs: (Seq[f64], Seq[f64])) -> out: f64 {
    $inputs                    -> dot_f64  -> $numerator
    $inputs                    -> first    -> norm_f64 -> $left_norm
    $inputs                    -> second   -> norm_f64 -> $right_norm
    ($left_norm, $right_norm)  -> math_mul -> $denominator
    ($numerator, $denominator) -> math_div -> expect   -> $out
}

extern node squared_distance_f64(inputs: (Seq[f64], Seq[f64])) -> total: f64 {
    $inputs -> sub_f64 -> squared_norm_f64 -> $total
}

extern node distance_f64(inputs: (Seq[f64], Seq[f64])) -> total: f64 {
    $inputs -> squared_distance_f64 -> math_sqrt -> expect -> $total
}

extern node sum_f32(values: Seq[f32]) -> total: f32 {
    0       -> from_int_f32                         -> $zero
    $values -> reduce math_add_f32(identity: $zero) -> $total
}

extern node mean_f32(values: Seq[f32]) -> average: f32 {
    $values          -> sum_f32      -> $total
    $values          -> length       -> from_int_f32 -> $count
    ($total, $count) -> math_div_f32 -> expect       -> $average
}

extern node min_f32(values: Seq[f32]) -> out: f32 {
    $values -> head -> expect                                  -> $initial
    $values -> tail -> reduce math_min_f32(identity: $initial) -> $out
}

extern node max_f32(values: Seq[f32]) -> out: f32 {
    $values -> head -> expect                                  -> $initial
    $values -> tail -> reduce math_max_f32(identity: $initial) -> $out
}

node add_pair_f32(pair: (f32, f32)) -> out: f32 {
    $pair -> math_add_f32 -> $out
}

node sub_pair_f32(pair: (f32, f32)) -> out: f32 {
    $pair -> math_sub_f32 -> $out
}

node mul_pair_f32(pair: (f32, f32)) -> out: f32 {
    $pair -> math_mul_f32 -> $out
}

node div_pair_f32(pair: (f32, f32)) -> out: f32 {
    $pair -> math_div_f32 -> expect -> $out
}

node eq_pair_f32(pair: (f32, f32)) -> out: Bool {
    $pair -> math_eq_f32 -> $out
}

node neg_value_f32(value: f32) -> out: f32 {
    $value -> math_neg_f32 -> $out
}

node abs_value_f32(value: f32) -> out: f32 {
    $value -> math_abs_f32 -> $out
}

extern node neg_f32(values: Seq[f32]) -> out: Seq[f32] {
    $values -> map neg_value_f32 -> $out
}

extern node abs_f32(values: Seq[f32]) -> out: Seq[f32] {
    $values -> map abs_value_f32 -> $out
}

node exp_value_f32(value: f32) -> out: f32 {
    $value -> math_exp_f32 -> $out
}

extern node exp_f32(values: Seq[f32]) -> out: Seq[f32] {
    $values -> map exp_value_f32 -> $out
}

extern node add_f32(inputs: (Seq[f32], Seq[f32])) -> out: Seq[f32] {
    $inputs -> zip -> map add_pair_f32 -> $out
}

extern node sub_f32(inputs: (Seq[f32], Seq[f32])) -> out: Seq[f32] {
    $inputs -> zip -> map sub_pair_f32 -> $out
}

extern node mul_f32(inputs: (Seq[f32], Seq[f32])) -> out: Seq[f32] {
    $inputs -> zip -> map mul_pair_f32 -> $out
}

extern node div_f32(inputs: (Seq[f32], Seq[f32])) -> out: Seq[f32] {
    $inputs -> zip -> map div_pair_f32 -> $out
}

extern node add_scalar_f32(inputs: (Seq[f32], f32)) -> out: Seq[f32] {
    $inputs -> broadcast_right -> map add_pair_f32 -> $out
}

extern node sub_scalar_f32(inputs: (Seq[f32], f32)) -> out: Seq[f32] {
    $inputs -> broadcast_right -> map sub_pair_f32 -> $out
}

extern node scalar_sub_f32(inputs: (f32, Seq[f32])) -> out: Seq[f32] {
    $inputs -> broadcast_left -> map sub_pair_f32 -> $out
}

extern node mul_scalar_f32(inputs: (Seq[f32], f32)) -> out: Seq[f32] {
    $inputs -> broadcast_right -> map mul_pair_f32 -> $out
}

extern node scalar_mul_f32(inputs: (f32, Seq[f32])) -> out: Seq[f32] {
    $inputs -> broadcast_left -> map mul_pair_f32 -> $out
}

extern node div_scalar_f32(inputs: (Seq[f32], f32)) -> out: Seq[f32] {
    $inputs -> broadcast_right -> map div_pair_f32 -> $out
}

extern node scalar_div_f32(inputs: (f32, Seq[f32])) -> out: Seq[f32] {
    $inputs -> broadcast_left -> map div_pair_f32 -> $out
}

extern node equals_f32(inputs: (Seq[f32], Seq[f32])) -> out: Bool {
    $inputs -> zip -> map eq_pair_f32 -> all -> $out
}

node dot_pair_f32(pair: (f32, f32)) -> product: f32 {
    $pair -> math_mul_f32 -> $product
}

extern node dot_f32(inputs: (Seq[f32], Seq[f32])) -> total: f32 {
    0       -> from_int_f32 -> $zero
    $inputs -> zip          -> map dot_pair_f32 -> reduce math_add_f32(identity: $zero) -> $total
}

node square_f32(value: f32) -> out: f32 {
    ($value, $value) -> math_mul_f32 -> $out
}

extern node squared_norm_f32(values: Seq[f32]) -> total: f32 {
    $values -> map square_f32 -> sum_f32 -> $total
}

extern node l1_norm_f32(values: Seq[f32]) -> total: f32 {
    $values -> abs_f32 -> sum_f32 -> $total
}

extern node norm_f32(values: Seq[f32]) -> total: f32 {
    $values -> squared_norm_f32 -> math_sqrt_f32 -> expect -> $total
}

extern node normalize_f32(values: Seq[f32]) -> out: Seq[f32] {
    $values               -> norm_f32       -> $magnitude
    ($values, $magnitude) -> div_scalar_f32 -> $out
}

node relu_value_f32(value: f32) -> out: f32 {
    0               -> from_int_f32 -> $zero
    ($value, $zero) -> math_max_f32 -> $out
}

extern node relu_f32(values: Seq[f32]) -> out: Seq[f32] {
    $values -> map relu_value_f32 -> $out
}

extern node sigmoid_f32(values: Seq[f32]) -> out: Seq[f32] {
    1                    -> from_int_f32   -> $one
    $values              -> neg_f32        -> exp_f32 -> $neg_exp
    ($neg_exp, $one)     -> add_scalar_f32 -> $denominator
    ($one, $denominator) -> scalar_div_f32 -> $out
}

extern node silu_f32(values: Seq[f32]) -> out: Seq[f32] {
    $values               -> sigmoid_f32 -> $activated
    ($values, $activated) -> mul_f32     -> $out
}

extern node softmax_f32(values: Seq[f32]) -> out: Seq[f32] {
    $values                     -> max_f32        -> $offset
    ($values, $offset)          -> sub_scalar_f32 -> exp_f32 -> $exp_values
    $exp_values                 -> sum_f32        -> $denominator
    ($exp_values, $denominator) -> div_scalar_f32 -> $out
}

extern node cosine_similarity_f32(inputs: (Seq[f32], Seq[f32])) -> out: f32 {
    $inputs                    -> dot_f32      -> $numerator
    $inputs                    -> first        -> norm_f32 -> $left_norm
    $inputs                    -> second       -> norm_f32 -> $right_norm
    ($left_norm, $right_norm)  -> math_mul_f32 -> $denominator
    ($numerator, $denominator) -> math_div_f32 -> expect   -> $out
}

extern node squared_distance_f32(inputs: (Seq[f32], Seq[f32])) -> total: f32 {
    $inputs -> sub_f32 -> squared_norm_f32 -> $total
}

extern node distance_f32(inputs: (Seq[f32], Seq[f32])) -> total: f32 {
    $inputs -> squared_distance_f32 -> math_sqrt_f32 -> expect -> $total
}
