import std.bytes { bytes_to_codes, byte_length }
import std.fault { expect }
import std.fs { read_file, write_file }
import std.math {
    abs_f64 as math_abs,
    add_f64 as math_add,
    div_f64 as math_div,
    gt_f64 as math_gt,
    max_f64 as math_max,
    min_f64 as math_min,
    mul_f64 as math_mul,
    neg_f64 as math_neg,
    sub_f64 as math_sub,
}
import std.real { from_int }
import std.seq { broadcast_right, flatten as seq_flatten, zip }
import std.tuple { first, second }
import std.cv.native {
    decode as decode_native,
    decode_bmp as decode_bmp_native,
    decode_jpeg as decode_jpeg_native,
    decode_png as decode_png_native,
    decode_pnm as decode_pnm_native,
    encode_bmp as encode_bmp_native,
    encode_jpeg as encode_jpeg_native,
    encode_pgm as encode_pgm_native,
    encode_png as encode_png_native,
    encode_ppm as encode_ppm_native,
}

type Size = (i64, i64)
type Pixel = (f64, (f64, f64))
type Image = (Size, Seq[Seq[Pixel]])

extern node dimensions(image: Image) -> shape: Size {
    $image -> first -> $shape
}

extern node width(image: Image) -> value: i64 {
    $image -> dimensions -> first -> $value
}

extern node height(image: Image) -> value: i64 {
    $image -> dimensions -> second -> $value
}

extern node pixels(image: Image) -> values: Seq[Pixel] {
    $image -> second -> seq_flatten -> $values
}

extern node pixel_rows(image: Image) -> values: Seq[Seq[Pixel]] {
    $image -> second -> $values
}

extern node map_pixels(inputs: (Image, Seq[Seq[Pixel]])) -> image: Image {
    $inputs           -> first  -> dimensions -> $shape
    $inputs           -> second -> $values
    ($shape, $values) -> $image
}

node clamp_channel(value: f64) -> out: f64 {
    ($value, 0.0) -> math_max -> $low
    ($low, 1.0)   -> math_min -> $out
}

node gray_value_to_srgb_pixel(value: f64) -> pixel: Pixel {
    $value                           -> clamp_channel -> $channel
    ($channel, ($channel, $channel)) -> $pixel
}

node gray_code_to_srgb_pixel(code: i64) -> pixel: Pixel {
    $code               -> from_int -> $real_code
    ($real_code, 255.0) -> math_div -> expect -> gray_value_to_srgb_pixel -> $pixel
}

node srgb_pixel_to_luma(pixel: Pixel) -> luma: f64 {
    $pixel                           -> first    -> $red
    $pixel                           -> second   -> $green_blue
    $green_blue                      -> first    -> $green
    $green_blue                      -> second   -> $blue
    ($red, 0.299)                    -> math_mul -> $red_weighted
    ($green, 0.587)                  -> math_mul -> $green_weighted
    ($blue, 0.114)                   -> math_mul -> $blue_weighted
    ($red_weighted, $green_weighted) -> math_add -> $rg
    ($rg, $blue_weighted)            -> math_add -> $luma
}

node srgb_pixel_to_gray_pixel(pixel: Pixel) -> out: Pixel {
    $pixel -> srgb_pixel_to_luma -> gray_value_to_srgb_pixel -> $out
}

extern node normalize(bytes: Bytes) -> image: Image {
    $bytes                   -> byte_length    -> $width
    $bytes                   -> bytes_to_codes -> map gray_code_to_srgb_pixel -> $values
    (($width, 1), [$values]) -> $image
}

extern node grayscale(image: Image) -> out: Image {
    $image            -> pixel_rows -> map grayscale_row -> $values
    ($image, $values) -> map_pixels -> $out
}

node grayscale_row(row: Seq[Pixel]) -> out: Seq[Pixel] {
    $row -> map srgb_pixel_to_gray_pixel -> $out
}

node invert_pixel(pixel: Pixel) -> out: Pixel {
    $pixel                              -> first    -> $red
    $pixel                              -> second   -> $green_blue
    $green_blue                         -> first    -> $green
    $green_blue                         -> second   -> $blue
    (1.0, $red)                         -> math_sub -> $out_red
    (1.0, $green)                       -> math_sub -> $out_green
    (1.0, $blue)                        -> math_sub -> $out_blue
    ($out_red, ($out_green, $out_blue)) -> $out
}

extern node invert(image: Image) -> out: Image {
    $image            -> pixel_rows -> map invert_row -> $values
    ($image, $values) -> map_pixels -> $out
}

node invert_row(row: Seq[Pixel]) -> out: Seq[Pixel] {
    $row -> map invert_pixel -> $out
}

node threshold_pixel(inputs: (Pixel, f64)) -> out: Pixel {
    $inputs             -> first                    -> srgb_pixel_to_luma -> $luma
    $inputs             -> second                   -> $threshold
    ($luma, $threshold) -> math_gt                  -> $above
    ($above, 1.0, 0.0)  -> select                   -> $channel
    $channel            -> gray_value_to_srgb_pixel -> $out
}

extern node threshold(inputs: (Image, f64)) -> out: Image {
    $inputs           -> first           -> $image
    $inputs           -> second          -> $cutoff
    $image            -> pixel_rows      -> $rows
    ($rows, $cutoff)  -> broadcast_right -> map threshold_row -> $values
    ($image, $values) -> map_pixels      -> $out
}

node threshold_row(inputs: (Seq[Pixel], f64)) -> out: Seq[Pixel] {
    $inputs         -> first           -> $row
    $inputs         -> second          -> $cutoff
    ($row, $cutoff) -> broadcast_right -> map threshold_pixel -> $out
}

node brighten_channel(inputs: (f64, f64)) -> out: f64 {
    $inputs -> math_add -> clamp_channel -> $out
}

node brighten_pixel(inputs: (Pixel, f64)) -> out: Pixel {
    $inputs                             -> first            -> $pixel
    $inputs                             -> second           -> $amount
    $pixel                              -> first            -> $red
    $pixel                              -> second           -> $green_blue
    $green_blue                         -> first            -> $green
    $green_blue                         -> second           -> $blue
    ($red, $amount)                     -> brighten_channel -> $out_red
    ($green, $amount)                   -> brighten_channel -> $out_green
    ($blue, $amount)                    -> brighten_channel -> $out_blue
    ($out_red, ($out_green, $out_blue)) -> $out
}

extern node brighten(inputs: (Image, f64)) -> out: Image {
    $inputs           -> first           -> $image
    $inputs           -> second          -> $amount
    $image            -> pixel_rows      -> $rows
    ($rows, $amount)  -> broadcast_right -> map brighten_row -> $values
    ($image, $values) -> map_pixels      -> $out
}

node brighten_row(inputs: (Seq[Pixel], f64)) -> out: Seq[Pixel] {
    $inputs         -> first           -> $row
    $inputs         -> second          -> $amount
    ($row, $amount) -> broadcast_right -> map brighten_pixel -> $out
}

extern node darken(inputs: (Image, f64)) -> out: Image {
    $inputs           -> first    -> $image
    $inputs           -> second   -> math_neg -> $amount
    ($image, $amount) -> brighten -> $out
}

node contrast_channel(inputs: (f64, f64)) -> out: f64 {
    $inputs              -> first    -> $channel
    $inputs              -> second   -> $factor
    ($channel, 0.5)      -> math_sub -> $centered
    ($centered, $factor) -> math_mul -> $scaled
    ($scaled, 0.5)       -> math_add -> clamp_channel -> $out
}

node contrast_pixel(inputs: (Pixel, f64)) -> out: Pixel {
    $inputs                             -> first            -> $pixel
    $inputs                             -> second           -> $factor
    $pixel                              -> first            -> $red
    $pixel                              -> second           -> $green_blue
    $green_blue                         -> first            -> $green
    $green_blue                         -> second           -> $blue
    ($red, $factor)                     -> contrast_channel -> $out_red
    ($green, $factor)                   -> contrast_channel -> $out_green
    ($blue, $factor)                    -> contrast_channel -> $out_blue
    ($out_red, ($out_green, $out_blue)) -> $out
}

extern node contrast(inputs: (Image, f64)) -> out: Image {
    $inputs           -> first           -> $image
    $inputs           -> second          -> $factor
    $image            -> pixel_rows      -> $rows
    ($rows, $factor)  -> broadcast_right -> map contrast_row -> $values
    ($image, $values) -> map_pixels      -> $out
}

node contrast_row(inputs: (Seq[Pixel], f64)) -> out: Seq[Pixel] {
    $inputs         -> first           -> $row
    $inputs         -> second          -> $factor
    ($row, $factor) -> broadcast_right -> map contrast_pixel -> $out
}

node red_channel_pixel(pixel: Pixel) -> out: Pixel {
    $pixel -> first -> gray_value_to_srgb_pixel -> $out
}

node green_channel_pixel(pixel: Pixel) -> out: Pixel {
    $pixel -> second -> first -> gray_value_to_srgb_pixel -> $out
}

node blue_channel_pixel(pixel: Pixel) -> out: Pixel {
    $pixel -> second -> second -> gray_value_to_srgb_pixel -> $out
}

node red_value(pixel: Pixel) -> out: f64 {
    $pixel -> first -> $out
}

node green_value(pixel: Pixel) -> out: f64 {
    $pixel -> second -> first -> $out
}

node blue_value(pixel: Pixel) -> out: f64 {
    $pixel -> second -> second -> $out
}

node luma_value(pixel: Pixel) -> out: f64 {
    $pixel -> srgb_pixel_to_luma -> $out
}

node red_matrix_row(row: Seq[Pixel]) -> out: Seq[f64] {
    $row -> map red_value -> $out
}

node green_matrix_row(row: Seq[Pixel]) -> out: Seq[f64] {
    $row -> map green_value -> $out
}

node blue_matrix_row(row: Seq[Pixel]) -> out: Seq[f64] {
    $row -> map blue_value -> $out
}

node luma_matrix_row(row: Seq[Pixel]) -> out: Seq[f64] {
    $row -> map luma_value -> $out
}

extern node red_matrix(image: Image) -> out: Seq[Seq[f64]] {
    $image -> pixel_rows -> map red_matrix_row -> $out
}

extern node green_matrix(image: Image) -> out: Seq[Seq[f64]] {
    $image -> pixel_rows -> map green_matrix_row -> $out
}

extern node blue_matrix(image: Image) -> out: Seq[Seq[f64]] {
    $image -> pixel_rows -> map blue_matrix_row -> $out
}

extern node luma_matrix(image: Image) -> out: Seq[Seq[f64]] {
    $image -> pixel_rows -> map luma_matrix_row -> $out
}

extern node red_channel(image: Image) -> out: Image {
    $image            -> pixel_rows -> map red_channel_row -> $values
    ($image, $values) -> map_pixels -> $out
}

extern node green_channel(image: Image) -> out: Image {
    $image            -> pixel_rows -> map green_channel_row -> $values
    ($image, $values) -> map_pixels -> $out
}

extern node blue_channel(image: Image) -> out: Image {
    $image            -> pixel_rows -> map blue_channel_row -> $values
    ($image, $values) -> map_pixels -> $out
}

node red_channel_row(row: Seq[Pixel]) -> out: Seq[Pixel] {
    $row -> map red_channel_pixel -> $out
}

node green_channel_row(row: Seq[Pixel]) -> out: Seq[Pixel] {
    $row -> map green_channel_pixel -> $out
}

node blue_channel_row(row: Seq[Pixel]) -> out: Seq[Pixel] {
    $row -> map blue_channel_pixel -> $out
}

node sepia_channel(inputs: (f64, (f64, (f64, (f64, (f64, f64)))))) -> out: f64 {
    $inputs                  -> first         -> $red
    $inputs                  -> second        -> first  -> $green
    $inputs                  -> second        -> second -> first  -> $blue
    $inputs                  -> second        -> second -> second -> first  -> $red_weight
    $inputs                  -> second        -> second -> second -> second -> $green_blue_weights
    $green_blue_weights      -> first         -> $green_weight
    $green_blue_weights      -> second        -> $blue_weight
    ($red, $red_weight)      -> math_mul      -> $red_part
    ($green, $green_weight)  -> math_mul      -> $green_part
    ($blue, $blue_weight)    -> math_mul      -> $blue_part
    ($red_part, $green_part) -> math_add      -> $rg
    ($rg, $blue_part)        -> math_add      -> $total
    $total                   -> clamp_channel -> $out
}

node sepia_pixel(pixel: Pixel) -> out: Pixel {
    $pixel                                             -> first         -> $red
    $pixel                                             -> second        -> $green_blue
    $green_blue                                        -> first         -> $green
    $green_blue                                        -> second        -> $blue
    ($red, ($green, ($blue, (0.393, (0.769, 0.189))))) -> sepia_channel -> $out_red
    ($red, ($green, ($blue, (0.349, (0.686, 0.168))))) -> sepia_channel -> $out_green
    ($red, ($green, ($blue, (0.272, (0.534, 0.131))))) -> sepia_channel -> $out_blue
    ($out_red, ($out_green, $out_blue))                -> $out
}

extern node sepia(image: Image) -> out: Image {
    $image            -> pixel_rows -> map sepia_row -> $values
    ($image, $values) -> map_pixels -> $out
}

node sepia_row(row: Seq[Pixel]) -> out: Seq[Pixel] {
    $row -> map sepia_pixel -> $out
}

node add_pixel_pair(pair: (Pixel, Pixel)) -> out: Pixel {
    $pair                       -> first    -> $left
    $pair                       -> second   -> $right
    $left                       -> first    -> $left_red
    $left                       -> second   -> first         -> $left_green
    $left                       -> second   -> second        -> $left_blue
    $right                      -> first    -> $right_red
    $right                      -> second   -> first         -> $right_green
    $right                      -> second   -> second        -> $right_blue
    ($left_red, $right_red)     -> math_add -> clamp_channel -> $red
    ($left_green, $right_green) -> math_add -> clamp_channel -> $green
    ($left_blue, $right_blue)   -> math_add -> clamp_channel -> $blue
    ($red, ($green, $blue))     -> $out
}

node sub_pixel_pair(pair: (Pixel, Pixel)) -> out: Pixel {
    $pair                       -> first    -> $left
    $pair                       -> second   -> $right
    $left                       -> first    -> $left_red
    $left                       -> second   -> first         -> $left_green
    $left                       -> second   -> second        -> $left_blue
    $right                      -> first    -> $right_red
    $right                      -> second   -> first         -> $right_green
    $right                      -> second   -> second        -> $right_blue
    ($left_red, $right_red)     -> math_sub -> clamp_channel -> $red
    ($left_green, $right_green) -> math_sub -> clamp_channel -> $green
    ($left_blue, $right_blue)   -> math_sub -> clamp_channel -> $blue
    ($red, ($green, $blue))     -> $out
}

node absdiff_pixel_pair(pair: (Pixel, Pixel)) -> out: Pixel {
    $pair                       -> first    -> $left
    $pair                       -> second   -> $right
    $left                       -> first    -> $left_red
    $left                       -> second   -> first    -> $left_green
    $left                       -> second   -> second   -> $left_blue
    $right                      -> first    -> $right_red
    $right                      -> second   -> first    -> $right_green
    $right                      -> second   -> second   -> $right_blue
    ($left_red, $right_red)     -> math_sub -> math_abs -> $red
    ($left_green, $right_green) -> math_sub -> math_abs -> $green
    ($left_blue, $right_blue)   -> math_sub -> math_abs -> $blue
    ($red, ($green, $blue))     -> $out
}

node add_row_pair(pair: (Seq[Pixel], Seq[Pixel])) -> out: Seq[Pixel] {
    $pair -> zip -> map add_pixel_pair -> $out
}

node sub_row_pair(pair: (Seq[Pixel], Seq[Pixel])) -> out: Seq[Pixel] {
    $pair -> zip -> map sub_pixel_pair -> $out
}

node absdiff_row_pair(pair: (Seq[Pixel], Seq[Pixel])) -> out: Seq[Pixel] {
    $pair -> zip -> map absdiff_pixel_pair -> $out
}

node left_image(inputs: (Image, Image)) -> image: Image {
    $inputs -> first -> $image
}

extern node add(inputs: (Image, Image)) -> out: Image {
    $inputs                       -> first      -> pixel_rows       -> $left_pixels
    $inputs                       -> second     -> pixel_rows       -> $right_pixels
    $inputs                       -> left_image -> $image
    ($left_pixels, $right_pixels) -> zip        -> map add_row_pair -> $values
    ($image, $values)             -> map_pixels -> $out
}

extern node sub(inputs: (Image, Image)) -> out: Image {
    $inputs                       -> first      -> pixel_rows       -> $left_pixels
    $inputs                       -> second     -> pixel_rows       -> $right_pixels
    $inputs                       -> left_image -> $image
    ($left_pixels, $right_pixels) -> zip        -> map sub_row_pair -> $values
    ($image, $values)             -> map_pixels -> $out
}

extern node absdiff(inputs: (Image, Image)) -> out: Image {
    $inputs                       -> first      -> pixel_rows           -> $left_pixels
    $inputs                       -> second     -> pixel_rows           -> $right_pixels
    $inputs                       -> left_image -> $image
    ($left_pixels, $right_pixels) -> zip        -> map absdiff_row_pair -> $values
    ($image, $values)             -> map_pixels -> $out
}

extern node decode(bytes: Bytes) -> image: Faultable[Image] {
    $bytes -> decode_native -> $image
}

extern node decode_bmp(bytes: Bytes) -> image: Faultable[Image] {
    $bytes -> decode_bmp_native -> $image
}

extern node decode_jpeg(bytes: Bytes) -> image: Faultable[Image] {
    $bytes -> decode_jpeg_native -> $image
}

extern node decode_png(bytes: Bytes) -> image: Faultable[Image] {
    $bytes -> decode_png_native -> $image
}

extern node decode_pnm(bytes: Bytes) -> image: Faultable[Image] {
    $bytes -> decode_pnm_native -> $image
}

extern node decode_pgm(bytes: Bytes) -> image: Faultable[Image] {
    $bytes -> decode_pnm -> $image
}

extern node decode_ppm(bytes: Bytes) -> image: Faultable[Image] {
    $bytes -> decode_pnm -> $image
}

extern node encode_bmp(image: Image) -> encoded: Faultable[Bytes] {
    $image -> encode_bmp_native -> $encoded
}

extern node encode_jpeg(image: Image) -> encoded: Faultable[Bytes] {
    $image -> encode_jpeg_native -> $encoded
}

extern node encode_pgm(image: Image) -> encoded: Faultable[Bytes] {
    $image -> encode_pgm_native -> $encoded
}

extern node encode_png(image: Image) -> encoded: Faultable[Bytes] {
    $image -> encode_png_native -> $encoded
}

extern node encode_ppm(image: Image) -> encoded: Faultable[Bytes] {
    $image -> encode_ppm_native -> $encoded
}

extern node load(path: Bytes) -> image: Faultable[Image] {
    $path -> read_file -> decode -> $image
}

extern node load_bmp(path: Bytes) -> image: Faultable[Image] {
    $path -> read_file -> decode_bmp -> $image
}

extern node load_jpeg(path: Bytes) -> image: Faultable[Image] {
    $path -> read_file -> decode_jpeg -> $image
}

extern node load_png(path: Bytes) -> image: Faultable[Image] {
    $path -> read_file -> decode_png -> $image
}

extern node load_pnm(path: Bytes) -> image: Faultable[Image] {
    $path -> read_file -> decode_pnm -> $image
}

extern node load_pgm(path: Bytes) -> image: Faultable[Image] {
    $path -> read_file -> decode_pgm -> $image
}

extern node load_ppm(path: Bytes) -> image: Faultable[Image] {
    $path -> read_file -> decode_ppm -> $image
}

extern node save_bmp(inputs: (Bytes, Image)) -> status: Faultable[i64] {
    $inputs           -> first      -> $path
    $inputs           -> second     -> encode_bmp -> $encoded
    ($path, $encoded) -> write_file -> $status
}

extern node save_jpeg(inputs: (Bytes, Image)) -> status: Faultable[i64] {
    $inputs           -> first      -> $path
    $inputs           -> second     -> encode_jpeg -> $encoded
    ($path, $encoded) -> write_file -> $status
}

extern node save_pgm(inputs: (Bytes, Image)) -> status: Faultable[i64] {
    $inputs           -> first      -> $path
    $inputs           -> second     -> encode_pgm -> $encoded
    ($path, $encoded) -> write_file -> $status
}

extern node save_png(inputs: (Bytes, Image)) -> status: Faultable[i64] {
    $inputs           -> first      -> $path
    $inputs           -> second     -> encode_png -> $encoded
    ($path, $encoded) -> write_file -> $status
}

extern node save_ppm(inputs: (Bytes, Image)) -> status: Faultable[i64] {
    $inputs           -> first      -> $path
    $inputs           -> second     -> encode_ppm -> $encoded
    ($path, $encoded) -> write_file -> $status
}
