# Generic JSON tokenizer in FlowArrow.
#
# Reads JSON from stdin, emits a flat SAX-style token stream to stdout,
# one token per line, formatted as:
#
#     <depth> <KIND> <text>
#
# Tokens kinds: OBJECT_START, OBJECT_END, ARRAY_START, ARRAY_END,
# COMMA, COLON, STRING, NUMBER, IDENT.
#
# The body of this parser is written in FlowArrow source. The compiler
# provides only primitive building blocks:
#
#   - bytes_to_codes / codes_to_bytes  : convert between Bytes and Seq[i64]
#   - scan op(identity: ...)           : parallel prefix scan (associative op)
#   - shift_right / zip / group_by_id  : sequence primitives
#   - bit_and / bit_or / bit_shl / bit_shr : i64 bit ops
#
# Algorithm (a textbook SIMD-style JSON tokenizer, but expressed as a
# static dataflow graph):
#
#   1. Convert the input bytes to a Seq[i64] of byte codes.
#   2. Per byte, encode a 4-state transition table T[i] as an i64.
#      States: OUT=0, STR=1, ESC=2, RUN=3.
#   3. scan compose_trans over T   -> fused transition from start
#      to each position.  Decode  state_after[i].
#   4. shift_right gives state_before[i].
#   5. Per byte, classify (state_before, byte) into a kind in 0..10
#      where -1 means "this byte is not the start of a token".
#   6. Prefix-sum the start flags to assign each byte a token id.
#   7. group_by_id collapses byte codes into per-token Seq[i64]
#      groups -> map codes_to_bytes -> Seq[Bytes].
#   8. Filter out whitespace tokens (kind == WS).
#   9. scan add over per-token depth deltas -> depth at each token.
#  10. Format kind+text+depth as lines and write to stdout.
import std.cli { Args }
import std.fault { expect }
import std.io { read_stdin, write_stdout }
import std.bytes { bytes_to_codes, codes_to_bytes, concat_bytes, join_bytes }
import std.int {
    format_int,
    bit_and,
    bit_or,
    bit_shl,
    bit_shr,
}
import std.seq { group_by_id, zip, shift_right }
import std.math { add, eq, ge, le }
import std.predicates { not, and, or }

program main(args: Args) -> exit_code: i64 {
    ()     -> read_stdin     -> $input
    $input -> bytes_to_codes -> $codes

    $codes -> map byte_to_trans -> $trans
    # 228 = identity transition: out[0]=0, out[1]=1, out[2]=2, out[3]=3
    # encoded as 0 | (1<<2) | (2<<4) | (3<<6) = 0 + 4 + 32 + 192 = 228.
    $trans -> scan compose_trans(identity: 228) -> $fused
    $fused -> map trans_to_state                -> $states_after

    ($states_after, 0)       -> shift_right -> $states_before
    ($states_before, $codes) -> zip         -> $sb_codes

    $sb_codes       -> map kind_at               -> $kinds_per_byte
    $kinds_per_byte -> map kind_to_start_int     -> $starts
    $starts         -> scan add_int(identity: 0) -> $token_ids

    ($codes, $token_ids) -> group_by_id        -> $code_groups
    $code_groups         -> map codes_to_bytes -> $texts_with_ws
    $kinds_per_byte      -> filter is_nonneg   -> $kinds_with_ws

    # Drop whitespace tokens (kind = 9).
    ($kinds_with_ws, $texts_with_ws) -> zip              -> $kt_ws
    $kt_ws                           -> filter kt_not_ws -> $kt
    $kt                              -> map kt_kind      -> $kinds
    $kt                              -> map kt_text      -> $texts

    $kinds  -> map depth_delta           -> $deltas
    $deltas -> scan add_int(identity: 0) -> $depths

    ($texts, $depths) -> zip              -> $td
    ($kinds, $td)     -> zip              -> $all_triples
    $all_triples      -> map format_token -> $lines
    ($lines, "")      -> join_bytes       -> $output

    $output -> write_stdout -> $exit_code
}

# ---------------------------------------------------------------------------
# Byte classification: encode per-byte state transition table as an i64.
#
# 4 states (2 bits each), encoded as: out[OUT] | out[STR]<<2 | out[ESC]<<4 | out[RUN]<<6
#
#   STRUCT bytes ({}[]:,)  -> 0b00_01_01_00 = 20    (OUT, RUN -> OUT; STR, ESC -> STR)
#   QUOTE  byte  (")       -> 0b01_01_00_01 = 81    (OUT, RUN -> STR; STR -> OUT; ESC -> STR)
#   BACK   byte  (\)       -> 0b11_01_10_11 = 219   (OUT, RUN -> RUN; STR -> ESC; ESC -> STR)
#   VAL    bytes (other)   -> 0b11_01_01_11 = 215   (OUT, RUN -> RUN; STR, ESC -> STR)
#   WS     bytes (\t \n \r space) -> same shape as STRUCT = 20
#
# Identity   -> 0b11_10_01_00 = 228 (each state maps to itself)
# ---------------------------------------------------------------------------
node byte_to_trans(b: i64) -> t: i64 {
    $b -> is_struct_byte -> $is_struct
    $b -> is_quote_byte  -> $is_quote
    $b -> is_back_byte   -> $is_back
    $b -> is_ws_byte     -> $is_ws

    # Cascading select. STRUCT == WS in transition shape (both 20).
    ($is_struct, $is_ws)           -> or     -> $is_low
    ($is_back, 219, 215)           -> select -> $t_after_back
    ($is_quote, 81, $t_after_back) -> select -> $t_after_quote
    ($is_low, 20, $t_after_quote)  -> select -> $t
}

# Each byte class is determined purely from the byte value.
node is_struct_byte(b: i64) -> r: Bool {
    ($b, 123)      -> eq -> $e_lb  # {
    ($b, 125)      -> eq -> $e_rb  # }
    ($b, 91)       -> eq -> $e_ls  # [
    ($b, 93)       -> eq -> $e_rs  # ]
    ($b, 44)       -> eq -> $e_co  # ,
    ($b, 58)       -> eq -> $e_cl  # :
    ($e_lb, $e_rb) -> or -> $s1
    ($s1, $e_ls)   -> or -> $s2
    ($s2, $e_rs)   -> or -> $s3
    ($s3, $e_co)   -> or -> $s4
    ($s4, $e_cl)   -> or -> $r
}

node is_quote_byte(b: i64) -> r: Bool {
    ($b, 34) -> eq -> $r  # "
}

node is_back_byte(b: i64) -> r: Bool {
    ($b, 92) -> eq -> $r  # \
}

node is_ws_byte(b: i64) -> r: Bool {
    ($b, 32)       -> eq -> $e_sp  # space
    ($b, 9)        -> eq -> $e_ht  # \t
    ($b, 10)       -> eq -> $e_lf  # \n
    ($b, 13)       -> eq -> $e_cr  # \r
    ($e_sp, $e_ht) -> or -> $w1
    ($w1, $e_lf)   -> or -> $w2
    ($w2, $e_cr)   -> or -> $r
}

# ---------------------------------------------------------------------------
# compose_trans: function-compose two encoded transition tables.
#   result[s] = b[a[s]]   for s in {0,1,2,3}
# ---------------------------------------------------------------------------
node compose_trans(a: i64, b: i64) -> c: i64 {
    $a -> trans_apply_0 -> $as0
    $a -> trans_apply_1 -> $as1
    $a -> trans_apply_2 -> $as2
    $a -> trans_apply_3 -> $as3

    ($b, $as0) -> trans_apply_at -> $c0_raw
    ($b, $as1) -> trans_apply_at -> $c1_raw
    ($b, $as2) -> trans_apply_at -> $c2_raw
    ($b, $as3) -> trans_apply_at -> $c3_raw

    ($c1_raw, 2) -> bit_shl -> $c1
    ($c2_raw, 4) -> bit_shl -> $c2
    ($c3_raw, 6) -> bit_shl -> $c3

    ($c0_raw, $c1) -> bit_or -> $p01
    ($c2, $c3)     -> bit_or -> $p23
    ($p01, $p23)   -> bit_or -> $c
}

node trans_apply_0(t: i64) -> s: i64 {
    ($t, 3) -> bit_and -> $s
}

node trans_apply_1(t: i64) -> s: i64 {
    ($t, 2) -> bit_shr -> $r
    ($r, 3) -> bit_and -> $s
}

node trans_apply_2(t: i64) -> s: i64 {
    ($t, 4) -> bit_shr -> $r
    ($r, 3) -> bit_and -> $s
}

node trans_apply_3(t: i64) -> s: i64 {
    ($t, 6) -> bit_shr -> $r
    ($r, 3) -> bit_and -> $s
}

# trans_apply_at(t, s): apply transition t to state s.
node trans_apply_at(t: i64, s: i64) -> r: i64 {
    ($s, 1)      -> bit_shl -> $shift
    ($t, $shift) -> bit_shr -> $raw
    ($raw, 3)    -> bit_and -> $r
}

node trans_to_state(t: i64) -> s: i64 {
    ($t, 3) -> bit_and -> $s
}

# ---------------------------------------------------------------------------
# Per-byte token classification: given (state_before, byte) compute a kind
# in 0..9, or -1 if the byte is not the start of a token.
#
#   0 OBJECT_START   {
#   1 OBJECT_END     }
#   2 ARRAY_START    [
#   3 ARRAY_END      ]
#   4 COMMA          ,
#   5 COLON          :
#   6 STRING         (token opens with ")
#   7 NUMBER         (token opens with digit/sign/dot)
#   8 IDENT          (token opens with letter etc.)
#   9 WS             (whitespace run)
#
# Token-start condition:
#     is_structural OR (state_before == OUT AND not is_ws)
#                   OR (state_before == RUN AND is_quote)
# ---------------------------------------------------------------------------
node kind_at(state_before: i64, b: i64) -> k: i64 {
    ($b, 123)      -> eq -> $e_lb
    ($b, 125)      -> eq -> $e_rb
    ($b, 91)       -> eq -> $e_ls
    ($b, 93)       -> eq -> $e_rs
    ($b, 44)       -> eq -> $e_co
    ($b, 58)       -> eq -> $e_cl
    ($e_lb, $e_rb) -> or -> $s1
    ($s1, $e_ls)   -> or -> $s2
    ($s2, $e_rs)   -> or -> $s3
    ($s3, $e_co)   -> or -> $s4
    ($s4, $e_cl)   -> or -> $is_struct

    $b -> is_quote_byte -> $is_quote
    $b -> is_ws_byte    -> $is_ws

    ($state_before, 0) -> eq -> $in_out
    ($state_before, 3) -> eq -> $in_run
    ($in_out, $in_run) -> or -> $in_outrun

    # numeric opener: digit (48..57), sign (43, 45), or dot (46).
    ($b, 48)             -> ge  -> $ge48
    ($b, 57)             -> le  -> $le57
    ($ge48, $le57)       -> and -> $is_digit
    ($b, 43)             -> eq  -> $e_plus
    ($b, 45)             -> eq  -> $e_minus
    ($b, 46)             -> eq  -> $e_dot
    ($is_digit, $e_plus) -> or  -> $n1
    ($n1, $e_minus)      -> or  -> $n2
    ($n2, $e_dot)        -> or  -> $is_numchar

    $is_ws                  -> not -> $not_ws
    ($in_out, $not_ws)      -> and -> $out_open_any
    ($in_outrun, $is_quote) -> and -> $opens_string

    # opens_ident: state_before==OUT and not (ws | struct | quote | numchar)
    ($is_struct, $is_quote) -> or  -> $sq
    ($sq, $is_numchar)      -> or  -> $sqn
    ($sqn, $is_ws)          -> or  -> $not_ident_byte_flag
    $not_ident_byte_flag    -> not -> $ident_byte
    ($in_out, $ident_byte)  -> and -> $opens_ident

    # opens_number: state_before==OUT and is_numchar
    ($in_out, $is_numchar) -> and -> $opens_number

    # opens_ws: state_before==OUT and is_ws
    ($in_out, $is_ws) -> and -> $opens_ws

    # Decode structural kind from byte
    ($e_cl, 5, -1)   -> select -> $ks5
    ($e_co, 4, $ks5) -> select -> $ks4
    ($e_rs, 3, $ks4) -> select -> $ks3
    ($e_ls, 2, $ks3) -> select -> $ks2
    ($e_rb, 1, $ks2) -> select -> $ks1
    ($e_lb, 0, $ks1) -> select -> $k_struct

    # Cascading selection of final kind. Order doesn't really matter because
    # the categories are mutually exclusive given the state_before.
    ($opens_ws, 9, -1)           -> select -> $k0
    ($opens_ident, 8, $k0)       -> select -> $k1
    ($opens_number, 7, $k1)      -> select -> $k2
    ($opens_string, 6, $k2)      -> select -> $k3
    ($is_struct, $k_struct, $k3) -> select -> $k
}

node kind_to_start_int(k: i64) -> n: i64 {
    ($k, 0)    -> ge     -> $b
    ($b, 1, 0) -> select -> $n
}

node is_nonneg(k: i64) -> b: Bool {
    ($k, 0) -> ge -> $b
}

node add_int(a: i64, b: i64) -> r: i64 {
    ($a, $b) -> add -> expect -> $r
}

# ---------------------------------------------------------------------------
# Filtering and projection on (kind, text) pairs.
# ---------------------------------------------------------------------------
node kt_not_ws(k: i64, t: Bytes) -> b: Bool {
    ($k, 9) -> eq  -> $is_ws
    $is_ws  -> not -> $b
}

node kt_kind(k: i64, t: Bytes) -> r: i64 {
    $k -> $r
}

node kt_text(k: i64, t: Bytes) -> r: Bytes {
    $t -> $r
}

# ---------------------------------------------------------------------------
# Depth tracking.
# ---------------------------------------------------------------------------
node depth_delta(k: i64) -> d: i64 {
    ($k, 0)             -> eq     -> $is_obs
    ($k, 2)             -> eq     -> $is_ars
    ($k, 1)             -> eq     -> $is_obe
    ($k, 3)             -> eq     -> $is_are
    ($is_obs, $is_ars)  -> or     -> $is_open
    ($is_obe, $is_are)  -> or     -> $is_close
    ($is_open, 1, 0)    -> select -> $a
    ($is_close, -1, $a) -> select -> $d
}

# ---------------------------------------------------------------------------
# Output formatting.
# ---------------------------------------------------------------------------
node kind_name(k: i64) -> name: Bytes {
    ($k, 0) -> eq -> $e0
    ($k, 1) -> eq -> $e1
    ($k, 2) -> eq -> $e2
    ($k, 3) -> eq -> $e3
    ($k, 4) -> eq -> $e4
    ($k, 5) -> eq -> $e5
    ($k, 6) -> eq -> $e6
    ($k, 7) -> eq -> $e7
    ($k, 8) -> eq -> $e8

    ($e8, "IDENT", "?")        -> select -> $n8
    ($e7, "NUMBER", $n8)       -> select -> $n7
    ($e6, "STRING", $n7)       -> select -> $n6
    ($e5, "COLON", $n6)        -> select -> $n5
    ($e4, "COMMA", $n5)        -> select -> $n4
    ($e3, "ARRAY_END", $n4)    -> select -> $n3
    ($e2, "ARRAY_START", $n3)  -> select -> $n2
    ($e1, "OBJECT_END", $n2)   -> select -> $n1
    ($e0, "OBJECT_START", $n1) -> select -> $name
}

# format_token gets a nested-tuple ((Bytes, (i64, i64)) packaging that arose
# from zip(zip(...)).  We destructure step by step.
node format_token(k: i64, td: (Bytes, i64)) -> line: Bytes {
    $k     -> kind_name  -> $name
    $k     -> format_int -> $kindnum
    $td    -> td_text    -> $text
    $td    -> td_depth   -> $depth
    $depth -> format_int -> $depth_str

    [$depth_str, " ", $name, " ", $text, "\n"] -> concat_bytes -> $line
}

node td_text(t: Bytes, d: i64) -> r: Bytes {
    $t -> $r
}

node td_depth(t: Bytes, d: i64) -> r: i64 {
    $d -> $r
}
