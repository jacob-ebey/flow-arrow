# add-numbers-from-args
#
# Reads command-line arguments as real numbers, sums them, writes the result
# (followed by a newline) to stdout, and returns the process exit code.
#
# Example:
#
#   $ flowarrow build main.flow
#   $ build/<target>/main 1.5 2.5 3
#   7

import std.bytes { concat_bytes }
import std.cli { Args, argv }
import std.io { write_stdout }
import std.real { parse_real, format_real }
import std.math { add }

program main(args: Args) -> exit_code: Faultable[Int] {
    $args -> argv -> $raw_args
    $raw_args -> map parse_real -> $numbers
    $numbers -> reduce add(identity: 0.0) -> $total
    $total -> format_real -> $total_bytes
    [$total_bytes, "\n"] -> concat_bytes -> $output
    $output -> write_stdout -> $exit_code
}
