# grep
#
# Reads a search needle and one or more file, directory, or glob targets
# from positional arguments, walks the targets, and prints every matching line
# as:
#
#   filepath:line-number:line
#
# Example:
#
#   $ flowarrow run main.flow needle ./src "*.flow"
import std.bytes {
    concat_bytes,
    contains,
    replace,
    split_lines,
    starts_with,
    trim,
}
import std.cli { Args, argv }
import std.fault { collect, expect }
import std.fs {
    dirname,
    exists,
    is_dir,
    join_path,
    read_file,
    read_files,
    walk_files,
}
import std.int { format_int }
import std.io { write_stdout }
import std.math { add_i64 as add }
import std.predicates { any, not, not_empty, or }
import std.seq {
    broadcast_right,
    concat,
    flatten,
    head,
    length,
    tail,
    zip,
}

program main(args: Args) -> exit_code: Faultable[i64] {
    $args     -> argv -> $raw_args
    $raw_args -> head -> $needle
    $raw_args -> tail -> $targets

    $targets                   -> head        -> $root_target
    $root_target               -> grep_config -> $root_config
    $root_config               -> ($, $ignore_filters)
    ($needle, $ignore_filters) -> $search_config

    $targets                         -> map walk_files  -> collect                -> flatten                   -> $walked_paths
    ($walked_paths, $ignore_filters) -> broadcast_right -> filter path_is_visible -> map path_from_filter_pair -> $paths
    ($paths, $search_config)         -> broadcast_right -> map grep_path          -> collect                   -> flatten -> $lines
    $walked_paths                    -> length          -> format_int             -> $walked_count
    $paths                           -> length          -> format_int             -> $file_count
    # summarize the walk and scan counts, and print the matches
    ["files walked: ", $walked_count, "\n", "files scanned: ", $file_count, "\n"] -> concat_bytes -> $summary
    $lines                                                                        -> concat_bytes -> $matches
    [$matches, $summary]                                                          -> concat_bytes -> $output
    $output                                                                       -> write_stdout -> $exit_code
}

node grep_config(root_target: Bytes) -> out: Faultable[(Bytes, Seq[Bytes])] {
    $root_target                                            -> is_dir            -> $root_is_dir
    $root_target                                            -> dirname           -> $root_parent
    ($root_is_dir, $root_target, $root_parent)              -> select            -> $root
    ($root, ".gitignore")                                   -> join_path         -> $gitignore_path
    $gitignore_path                                         -> exists            -> $has_gitignore
    ($has_gitignore, [$gitignore_path], [])                 -> select            -> $gitignore_paths
    $gitignore_paths                                        -> read_files        -> $gitignore_files
    $gitignore_files                                        -> map file_contents -> concat_bytes -> split_lines -> map trim -> $gitignore_filters
    (["/.git/", ".git/", ".gitignore"], $gitignore_filters) -> concat            -> $ignore_filters
    ($root, $ignore_filters)                                -> $out
}

node grep_path(input: (Bytes, (Bytes, Seq[Bytes]))) -> out: Faultable[Seq[Bytes]] {
    $input
    -> match {
        grep_path_is_ignored() -> no_matches
        _ -> grep_visible_path
    }
    -> $out
}

node no_paths(input: Bytes) -> out: Seq[Bytes] {
    [""] -> tail -> $out
}

node one_path(input: Bytes) -> out: Faultable[Seq[Bytes]] {
    [$input] -> $out
}

node grep_visible_path(input: (Bytes, (Bytes, Seq[Bytes]))) -> out: Faultable[Seq[Bytes]] {
    $input                      -> ($path, ($needle, $ignore_filters))
    $path                       -> read_file -> expect -> $contents
    ($path, $contents, $needle) -> grep_file -> $out
}

node no_matches(input: (Bytes, (Bytes, Seq[Bytes]))) -> out: Seq[Bytes] {
    [""] -> tail -> $out
}

node grep_path_is_ignored(input: (Bytes, (Bytes, Seq[Bytes]))) -> out: Bool {
    $input                   -> ($path, ($needle, $ignore_filters))
    ($path, $ignore_filters) -> path_matches_filters -> $out
}

node path_is_visible(input: (Bytes, Seq[Bytes])) -> out: Bool {
    $input -> path_matches_filters -> not -> $out
}

node path_matches_filters(input: (Bytes, Seq[Bytes])) -> out: Bool {
    $input                   -> ($path, $ignore_filters)
    ($ignore_filters, $path) -> broadcast_right -> map path_contains_filter -> any -> $out
}

node path_from_filter_pair(input: (Bytes, Seq[Bytes])) -> out: Bytes {
    $input -> ($path, $ignore_filters)
    $path  -> $out
}

node path_contains_filter(input: (Bytes, Bytes)) -> out: Bool {
    $input
    -> match {
        ignore_filter_inactive() -> false
        _ -> path_contains_active_filter
    }
    -> $out
}

node ignore_filter_inactive(input: (Bytes, Bytes)) -> out: Bool {
    $input             -> ($filter, $path)
    $filter            -> not_empty   -> not -> $empty
    ($filter, "#")     -> starts_with -> $comment
    ($empty, $comment) -> or          -> $out
}

node path_contains_active_filter(input: (Bytes, Bytes)) -> out: Bool {
    $input                      -> ($filter, $path)
    ($filter, "*", "")          -> replace  -> $normalized_filter
    ($path, $normalized_filter) -> contains -> $out
}

node file_contents(input: (Bytes, Bytes)) -> out: Bytes {
    $input    -> ($path, $contents)
    $contents -> $out
}

node grep_file(input: (Bytes, Bytes, Bytes)) -> out: Seq[Bytes] {
    $input    -> ($path, $contents, $needle)
    $contents -> split_lines -> $lines

    $lines                  -> length     -> $line_count
    ($line_count, 1)        -> add        -> expect -> $line_stop
    (1, $line_stop, 1)      -> range_step -> $line_numbers
    ($line_numbers, $lines) -> zip        -> $numbered_lines

    ($numbered_lines, $needle) -> broadcast_right -> filter line_contains -> $matches
    ($matches, $path)          -> broadcast_right -> map format_match     -> $out
}

node line_contains(input: ((i64, Bytes), Bytes)) -> keep: Bool {
    $input           -> (($line_number, $line), $needle)
    ($line, $needle) -> contains -> $keep
}

node format_match(input: (((i64, Bytes), Bytes), Bytes)) -> out: Bytes {
    $input                                            -> ((($line_number, $line), $needle), $path)
    $line_number                                      -> format_int   -> $line_number_text
    [$path, ":", $line_number_text, ":", $line, "\n"] -> concat_bytes -> $out
}
