# concurrency
#
# Builds a sequence of independent jobs, scores every job with a pure node,
# computes two aggregate views of the scores, and writes a deterministic
# summary to stdout.
#
# Demonstrates:
#   - explicit data-parallel work via `map score_job`
#   - independent downstream reductions over the same mapped values
#   - deterministic output without time, mutation, or thread identity
import std.bytes { concat_bytes }
import std.cli { Args }
import std.int { format_int }
import std.io { write_stdout }
import std.math { add, max, mul }

program main(args: Args) -> exit_code: Int {
    (1, 17, 1)      -> range_step              -> $jobs
    $jobs           -> map score_job           -> $scores
    $scores         -> reduce add(identity: 0) -> $total
    $scores         -> reduce max(identity: 0) -> $peak
    ($total, $peak) -> render_summary          -> $output
    $output         -> write_stdout            -> $exit_code
}

node score_job(n: Int) -> score: Int {
    ($n, $n)      -> mul -> $square
    ($square, $n) -> add -> $score
}

node render_summary(total: Int, peak: Int) -> output: Bytes {
    $total -> format_int -> $total_bytes
    $peak  -> format_int -> $peak_bytes

    ["jobs: 16\n", "total score: ", $total_bytes, "\n", "peak score: ", $peak_bytes, "\n"] -> concat_bytes -> $output
}
