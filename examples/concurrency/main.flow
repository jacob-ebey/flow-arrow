# concurrency
#
# Builds a sequence of independent jobs, maps them through two pure nodes,
# computes aggregate views of both mapped sequences, and writes a deterministic
# summary to stdout.
#
# Demonstrates:
#   - explicit data-parallel work via `map score_job`
#   - a second independent data-parallel region via `map weight_job`
#   - independent downstream reductions over the same mapped values
#   - deterministic output without time, mutation, or thread identity
import std.bytes { concat_bytes }
import std.cli { Args }
import std.int { format_int }
import std.io { write_stdout }
import std.math { add, max, mul }

struct JobSummary {
    total_score: i64,
    peak_score: i64,
    total_weight: i64,
    peak_weight: i64,
}

program main(args: Args) -> exit_code: i64 {
    (1, 17, 1) -> range_step              -> $jobs
    $jobs      -> map score_job           -> $scores
    $jobs      -> map weight_job          -> $weights
    $scores    -> reduce add(identity: 0) -> $total_score
    $scores    -> reduce max(identity: 0) -> $peak_score
    $weights   -> reduce add(identity: 0) -> $total_weight
    $weights   -> reduce max(identity: 0) -> $peak_weight
    JobSummary {
        total_score: $total_score,
        peak_score: $peak_score,
        total_weight: $total_weight,
        peak_weight: $peak_weight
    } -> $summary
    $summary -> render_summary -> $output
    $output  -> write_stdout   -> $exit_code
}

node score_job(n: i64) -> score: i64 {
    ($n, $n)      -> mul -> $square
    ($square, $n) -> add -> $score
}

node weight_job(n: i64) -> weight: i64 {
    ($n, 2)       -> mul -> $doubled
    ($doubled, 1) -> add -> $weight
}

node render_summary(summary: JobSummary) -> output: Bytes {
    $summary -> field total_score  -> $total_score
    $summary -> field peak_score   -> $peak_score
    $summary -> field total_weight -> $total_weight
    $summary -> field peak_weight  -> $peak_weight

    $total_score  -> format_int -> $total_score_bytes
    $peak_score   -> format_int -> $peak_score_bytes
    $total_weight -> format_int -> $total_weight_bytes
    $peak_weight  -> format_int -> $peak_weight_bytes

    ["jobs: 16\n", "total score: ", $total_score_bytes, "\n", "peak score: ", $peak_score_bytes, "\n", "total weight: ", $total_weight_bytes, "\n", "peak weight: ", $peak_weight_bytes, "\n"] -> concat_bytes -> $output
}
