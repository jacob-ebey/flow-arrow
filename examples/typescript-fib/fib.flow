# Exports a pure Fibonacci node for the TypeScript and JavaScript targets.
import std.math { add }

extern node fib(depth: Int) -> result: Int {
    (0, 1) -> repeat<$depth> fib_step -> ($result, $)
}

node fib_step(a: Int, b: Int) -> (next_a: Int, next_b: Int) {
    $b       -> $next_a
    ($a, $b) -> add -> $next_b
}
