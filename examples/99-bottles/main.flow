# 99-bottles
#
# Prints the canonical "99 bottles of beer on the wall" song.
#
# Demonstrates:
#   - generating a verse sequence with range_step
#   - producing one verse per index via map
#   - concatenating verses in order via reduce on an associative,
#     non-commutative operator (byte concatenation)
#   - emitting the final "no more bottles" verse as a join, not a branch
#   - grammatical pluralisation via the pure `select` combinator
#     ("1 bottle" vs "N bottles") — no `if` in the graph
#
# Dataflow shape:
#
#   ()  ─> range_step(99, 0, -1) ─> indices
#       indices ─> map verse_for ─> verses
#       verses ─> reduce concat_bytes(identity: "") ─> body
#       (body, final_verse) ─> concat2 ─> write_stdout ─> exit_code
import std.bytes { concat_bytes }
import std.cli { Args }
import std.io { write_stdout }
import std.int { format_int }
import std.math { sub, eq }

program main(args: Args) -> exit_code: Int {
    (99, 0, -1)    -> range_step                        -> $indices
    $indices       -> map verse_for                     -> $verses
    $verses        -> reduce concat_bytes(identity: "") -> $body
    ()             -> final_verse_node                  -> $tail
    [$body, $tail] -> concat_bytes                      -> $output
    $output        -> write_stdout                      -> $exit_code
}

# A single verse, parameterised by the current bottle count `n`.
#
#   "n bottles of beer on the wall, n bottles of beer.\n"
#   "Take one down and pass it around, (n-1) bottles of beer on the wall.\n\n"
#
node verse_for(n: Int) -> v: Bytes {
    $n      -> format_int -> $n_str
    ($n, 1) -> sub        -> $m
    $m      -> format_int -> $m_str

    # Pluralisation: "bottle" when count == 1, "bottles" otherwise.
    # Pure data selection — no branch hides in the graph.
    ($n, 1)                          -> eq     -> $n_is_one
    ($m, 1)                          -> eq     -> $m_is_one
    ($n_is_one, "bottle", "bottles") -> select -> $n_word
    ($m_is_one, "bottle", "bottles") -> select -> $m_word

    # Line 1: "{n} {n_word} of beer on the wall, {n} {n_word} of beer.\n"
    [$n_str, " ", $n_word, " of beer on the wall, ", $n_str, " ", $n_word, " of beer.\n"] -> concat_bytes -> $line1

    # Line 2: "Take one down and pass it around, {m} {m_word} of beer on the wall.\n\n"
    ["Take one down and pass it around, ", $m_str, " ", $m_word, " of beer on the wall.\n\n"] -> concat_bytes -> $line2

    [$line1, $line2] -> concat_bytes -> $v
}

# Final verse: "No more bottles of beer on the wall, no more bottles of beer.
#               Go to the store and buy some more, 99 bottles of beer on the wall.\n"
#
# Pure: depends on no inputs other than the literal constants.
node final_verse_node() -> v: Bytes {
    ["No more bottles of beer on the wall, no more bottles of beer.\n", "Go to the store and buy some more, 99 bottles of beer on the wall.\n"] -> concat_bytes -> $v
}
