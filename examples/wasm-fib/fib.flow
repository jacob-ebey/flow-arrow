# Exports a pure Fibonacci node for the wasm32-unknown-unknown cdylib target.
import std.math { add }

node fib(depth: Int) -> result: Int {
    (0, 1) -> repeat<$depth> _fib_step -> ($result, $)
}

node _fib_step(a: Int, b: Int) -> (next_a: Int, next_b: Int) {
    $b       -> $next_a
    ($a, $b) -> add -> $next_b
}
